{
    "$schema": "../schema/app.schema.json",
    "slug": "care_ai_widgets_fe",
    "name": "CARE AI Widgets",
    "description": "CARE frontend plugin that adds AI-powered clinical widgets to the encounter overview — configurable, prompt-driven summaries, scores, ranked lists, and rich markdown rendered directly inside the patient chart.",
    "featured": false,
    "iconUrl": "../assets/care-ai-widgets.svg",
    "developer": {
        "slug": "ohcnetwork",
        "name": "Open Healthcare Network",
        "url": "https://github.com/ohcnetwork"
    },
    "categories": [
        {
            "slug": "productivity",
            "name": "Productivity",
            "description": "Admin-facing tools and workflow accelerators."
        }
    ],
    "baseConfig": {
        "url": "https://care-ai-widgets-fe.pages.dev/assets/remoteEntry.js",
        "name": "care_ai_widgets_fe",
        "plug": "care_ai_widgets_fe"
    },
    "healthCheck": {
        "url": "{{apiUrl}}/api/care_ai/ping",
        "method": "GET",
        "successStatus": 200
    },
    "source": {
        "repository": "https://github.com/ohcnetwork/care_ai_widgets_fe",
        "appBaseUrl": "http://localhost:10121"
    },
    "standardConfigurations": [
        {
            "id": "local-dev",
            "title": "Local development",
            "description": "Attach the local preview output from care_ai_widgets_fe for development and manual testing.",
            "config": {
                "mode": "local"
            },
            "appBaseUrl": {
                "label": "App base URL",
                "description": "Base URL where the frontend plug is served.",
                "defaultValue": "http://localhost:10121"
            },
            "environments": {
                "mandatory": [],
                "defaults": [],
                "optional": [],
                "custom": {
                    "enabled": false,
                    "label": "Custom environments",
                    "description": "Add extra environment variables for advanced setup."
                }
            }
        },
        {
            "id": "production",
            "title": "Production",
            "description": "Production configuration for care_ai_widgets_fe.",
            "config": {
                "mode": "production"
            },
            "appBaseUrl": {
                "label": "App base URL",
                "description": "Base URL where the frontend plug is served.",
                "defaultValue": "https://care-ai-widgets-fe.pages.dev"
            },
            "environments": {
                "mandatory": [],
                "defaults": [],
                "optional": [],
                "custom": {
                    "enabled": false,
                    "label": "Custom environments",
                    "description": "Add extra environment variables for advanced setup."
                }
            }
        }
    ],
    "rawSetup": {
        "id": "raw-setup",
        "title": "Raw setup",
        "description": "Start with a minimal plug_config and edit it directly.",
        "config": {
            "mode": "manual"
        },
        "appBaseUrl": {
            "label": "App base URL",
            "defaultValue": "https://care-ai-widgets-fe.pages.dev"
        },
        "environments": {
            "mandatory": [],
            "defaults": [],
            "custom": {
                "enabled": true,
                "label": "Custom environments"
            }
        }
    }
}